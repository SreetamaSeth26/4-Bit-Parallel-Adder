module tb;
  reg [3:0] A,B;
  reg Cin;
  wire [3:0] S;
  wire Cout;
  
  parallel_adder UUT(A,B,Cin,S,Cout);
  
  initial
    begin
      $dumpfile("dump.vcd");
      $dumpvars(0,tb);
      $monitor("Cin = %b A = %b B = %b || Cout = %b Sum = %b",Cin,A,B,Cout,S);
      
      Cin=0;A=4'b0000;B=4'b0000;
      #10 Cin=0;A=4'b0011;B=4'b0101;
      #10 Cin=0;A=4'b1111;B=4'b0001;
      #10 Cin=1;A=4'b1010;B=4'b0101;
      
      #10 $finish;
    end
endmodule
